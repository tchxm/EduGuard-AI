{
  "name": "eduguard-ai",
  "version": "2.0.0",
  "description": "Modern AI-powered educational attendance system with face recognition",
  "private": true,
  "scripts": {
    "dev": "turbo run dev --parallel",
    "dev:backend": "cd packages/backend && pnpm dev",
    "dev:frontend": "cd packages/frontend && pnpm dev",
    "build": "turbo run build",
    "build:backend": "cd packages/backend && pnpm build",
    "build:frontend": "cd packages/frontend && pnpm build",
    "start": "turbo run start",
    "start:backend": "cd packages/backend && pnpm start",
    "start:frontend": "cd packages/frontend && pnpm start",
    "test": "turbo run test",
    "test:backend": "cd packages/backend && pnpm test",
    "test:frontend": "cd packages/frontend && pnpm test",
    "lint": "turbo run lint",
    "format": "prettier --write .",
    "db:push": "cd packages/backend && pnpm prisma db push",
    "db:migrate": "cd packages/backend && pnpm prisma migrate dev",
    "db:studio": "cd packages/backend && pnpm prisma studio",
    "db:seed": "cd packages/backend && pnpm prisma db seed",
    "db:reset": "cd packages/backend && pnpm prisma migrate reset",
    "docker:build": "docker-compose build",
    "docker:up": "docker-compose up -d",
    "docker:down": "docker-compose down",
    "docker:logs": "docker-compose logs -f",
    "setup": "pnpm install && pnpm db:push && echo 'Setup complete!'",
    "clean": "turbo run clean && rm -rf node_modules packages/*/node_modules packages/*/.next packages/*/dist"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^6.20.0",
    "@typescript-eslint/parser": "^6.20.0",
    "eslint": "^8.56.0",
    "prettier": "^3.1.1",
    "turbo": "^1.11.2",
    "typescript": "^5.3.3"
  },
  "engines": {
    "node": ">=18.0.0",
    "pnpm": ">=8.0.0"
  },
  "dependencies": {
    "@fastify/cors": "^11.2.0",
    "@fastify/helmet": "^13.0.2",
    "@fastify/jwt": "^10.0.0",
    "@fastify/rate-limit": "^10.3.0",
    "@prisma/client": "^7.4.2",
    "axios": "^1.13.6",
    "bcryptjs": "^3.0.3",
    "clsx": "^2.1.1",
    "dotenv": "^17.3.1",
    "fastify": "^5.8.2",
    "next": "^16.1.6",
    "pino": "^10.3.1",
    "react": "^19.2.4",
    "recharts": "^3.8.0",
    "sharp": "^0.34.5",
    "swr": "^2.4.1",
    "tailwindcss": "^4.2.1",
    "zod": "^4.3.6",
    "zustand": "^5.0.11"
  }
}
