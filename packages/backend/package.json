{
  "name": "@eduguard/backend",
  "version": "2.0.0",
  "description": "Fastify backend for EduGuard AI",
  "private": true,
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "dev": "node --loader tsx --watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "test": "vitest",
    "lint": "eslint src --ext .ts",
    "migrate": "prisma migrate dev",
    "migrate:deploy": "prisma migrate deploy",
    "prisma:generate": "prisma generate"
  },
  "dependencies": {
    "@prisma/client": "^5.8.0",
    "bcryptjs": "^2.4.3",
    "fastify": "^4.25.2",
    "fastify-cors": "^8.5.0",
    "fastify-helmet": "^11.1.1",
    "fastify-jwt": "^7.2.4",
    "fastify-multer": "^2.0.2",
    "fastify-rate-limit": "^9.1.0",
    "zod": "^3.22.4",
    "dotenv": "^16.3.1",
    "nodemailer": "^6.9.7",
    "sharp": "^0.33.1",
    "ioredis": "^5.3.2",
    "pino": "^8.17.2",
    "pino-pretty": "^10.3.1"
  },
  "devDependencies": {
    "@types/node": "^20.10.6",
    "@types/nodemailer": "^6.4.14",
    "@typescript-eslint/eslint-plugin": "^6.20.0",
    "@typescript-eslint/parser": "^6.20.0",
    "eslint": "^8.56.0",
    "prisma": "^5.8.0",
    "tsx": "^4.7.0",
    "typescript": "^5.3.3",
    "vitest": "^1.1.1"
  }
}
